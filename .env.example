# Environment variables for crm-backend
# Copy to .env and adjust as needed

# ─── App ─────────────────────────────────────────────────────────────────────
APP_NAME=CRM Backend
# Set to false in production (disables auto-reload, enables stricter checks)
APP_DEBUG=false
# Bind to all interfaces so the server is reachable on the public IP
APP_HOST=0.0.0.0
APP_PORT=8000

# ─── HTTPS / Session cookies ─────────────────────────────────────────────────
# Keep false when running on plain HTTP (most cloud VPS deployments).
# Set to true ONLY if you have a valid SSL certificate and Nginx/Caddy HTTPS.
# If this is true on HTTP, logins will silently fail because the browser
# refuses to send Secure cookies over plain HTTP.
APP_HTTPS_ONLY=false

# ─── Security ────────────────────────────────────────────────────────────────
# IMPORTANT: Replace with a long random string before going live.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=10080
ALGORITHM=HS256

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data.db
# For PostgreSQL: postgresql+asyncpg://user:password@localhost:5432/crm

# ─── CORS ────────────────────────────────────────────────────────────────────
# Use ["*"] to allow any origin (recommended for public cloud deployments).
# Lock down to specific origins once you have a fixed domain/IP.
CORS_ORIGINS=["*"]

# SMTP (Email) — required for verification codes and meeting invites
# If not provided, emails will be logged to console in development.
# Common settings:
# - Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_USE_TLS=true (needs App Password)
# - Office 365: SMTP_HOST=smtp.office365.com, SMTP_PORT=587, SMTP_USE_TLS=true
# - Zoho: SMTP_HOST=smtp.zoho.com, SMTP_PORT=587, SMTP_USE_TLS=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# Google OAuth and Calendar Integration
# Get these from Google Cloud Console: https://console.cloud.google.com/
# 1. Create a new project or select existing
# 2. Enable Google Calendar API
# 3. Create OAuth 2.0 credentials (Web application)
# 4. Add authorized redirect URI: http://localhost:8000/web/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8000/web/auth/google/callback
# For production, update the redirect URI to your domain:
# GOOGLE_REDIRECT_URI=https://yourdomain.com/web/auth/google/callback
